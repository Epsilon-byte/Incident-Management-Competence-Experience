# System variables
# For most Linux / WSL environments 1000 works
UID=1000
GID=1000

# Elasticsearch password
# Change if required
elasticsearch_password=CHANGE_ME

# Cortex job directory (relative path works on all systems)
cortex_docker_job_directory=./cortex/cortex-jobs

# Container versions
cassandra_image_version=4.1.10
elasticsearch_image_version=8.19.11
thehive_image_version=5.6.0
cortex_image_version=4.0.0
nginx_image_version=1.29.5

# Nginx configuration
nginx_server_name=localhost
nginx_ssl_trusted_certificate=