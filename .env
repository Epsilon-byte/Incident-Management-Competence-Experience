# System variables
UID=1000
GID=1000

# ElasticSearch password
elasticsearch_password=secure_password

# Image versions
cassandra_image_version=3.11
elasticsearch_image_version=7.17.11
thehive_image_version=5.6.2 # Updated to the latest version
nginx_image_version=1.21

# Nginx configuration
nginx_server_name=localhost
nginx_ssl_trusted_certificate=/path/to/certificate # Replace with the actual path to your SSL certificate

# TheHive configuration
HIVE_BASE_URL=https://localhost:9000
HIVE_HTTP_PORT=9000
HIVE_SECRET=super_secure_random_key # Replace with a secure, random string

# Cortex integration
CORTEX_URL=https://localhost:8443
CORTEX_KEY=your_cortex_api_key # Replace with the actual Cortex API key

# Database configuration
DB_HOST=cassandra
DB_PORT=9042
DB_NAME=thehive
DB_USER=cassandra
DB_PASSWORD=secure_password # Replace with your Cassandra password

# Elasticsearch configuration
ES_HOST=elasticsearch
ES_PORT=9200